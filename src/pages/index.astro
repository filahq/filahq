	.origin__item {
		padding: 1rem;
		border: 1px solid rgba(255, 255, 255, 0.08);
		border-radius: 1.5rem;
		background: rgba(255, 255, 255, 0.05);
	}

	.origin__label {
		margin-bottom: 0.85rem;
		font-family: var(--font-mono);
		font-size: 0.75rem;
