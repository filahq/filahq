		mask-image: linear-gradient(180deg, rgba(0, 0, 0, 0.85), transparent);
	}

	.signal-grid__beam {
		position: absolute;
		background: linear-gradient(90deg, transparent, rgba(255, 204, 0, 0.8), transparent);
	}

	.signal-grid__beam--one {
		top: 42%;
		left: 18%;
		width: 64%;
		height: 2px;
	}

	.signal-grid__beam--two {
		top: 24%;
		left: 45%;
		width: 2px;
		height: 54%;
		background: linear-gradient(180deg, transparent, rgba(255, 204, 0, 0.85), transparent);
	}

	.signal-node,
	.signal-grid__card {
		position: absolute;
		border: 1px solid rgba(255, 255, 255, 0.1);
		border-radius: 1.2rem;
		background: rgba(23, 23, 23, 0.75);
		backdrop-filter: blur(10px);
	}

	.signal-node {
		display: grid;
		place-items: center;
		min-width: 7rem;
		min-height: 4.5rem;
		padding: 0.85rem 1rem;
		text-align: center;
		font-weight: 700;
	}

	.signal-node span {
		display: block;
		max-width: 7ch;
	}

	.signal-node--core {
		top: 33%;
		left: 35%;
		min-width: 8.5rem;
		min-height: 5rem;
		border-color: rgba(255, 204, 0, 0.5);
		box-shadow: 0 0 0 1px rgba(255, 204, 0, 0.2), 0 1rem 2rem rgba(255, 204, 0, 0.15);
	}

	.signal-node--chrome {
		top: 10%;
		right: 8%;
	}

	.signal-node--desktop {
		bottom: 12%;
		right: 10%;
	}

	.signal-node--tablet {
		top: 20%;
		left: 10%;
	}

	.signal-node--mobile {
		bottom: 16%;
		left: 8%;
	}

	.signal-grid__card {
		right: 7%;
		bottom: 6%;
		padding: 1rem 1.1rem;
	}

	.signal-grid__card p + p {
		margin-top: 0.35rem;
		color: var(--color-signal);
	}

	.section {
		padding: 4rem 0;
	}

	.section-heading {
		max-width: 48rem;
	}

	.section-heading h2 {
		margin-top: 0.7rem;
		font-size: clamp(2rem, 4vw, 3.3rem);
		line-height: 1.02;
		letter-spacing: -0.04em;
	}

	.workflow__line {
		width: 100%;
		height: 1px;
		margin: 2rem 0 0;
		background: linear-gradient(90deg, rgba(255, 255, 255, 0), rgba(255, 204, 0, 0.9), rgba(255, 255, 255, 0));
	}

	.workflow__grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1.25rem;
		margin-top: 1.6rem;
	}

	.workflow__item,
	.future__content,
	.closing__panel {
		background: rgba(255, 255, 255, 0.05);
		border: 1px solid rgba(255, 255, 255, 0.08);
		border-radius: 1.6rem;
	}

	.workflow__item {
		padding: 1.6rem;
	}

	.workflow__item h3,
	.product h3 {
		margin-top: 0.8rem;
		font-size: 1.6rem;
		letter-spacing: -0.03em;
	}

